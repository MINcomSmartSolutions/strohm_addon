<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Dunning (Mahnwesen) Cron Job - runs daily -->
        <record id="ir_cron_dunning_process" model="ir.cron">
            <field name="name">Dunning Process (Mahnwesen)</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_dunning()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
